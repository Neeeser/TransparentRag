        "namespace": "col-{collection_id}",
        "top_k": null,
        "backend": "pgvector"
      },
      "hidden": false
    },
    {
      "type": "retriever.bm25",
      "label": "BM25 Retriever",
      "category": "retrieval",
      "description": "Query a sparse BM25 index with the raw query text for exact-term (lexical) matches \u2014 no embeddings involved.",
      "example": "QueryRequest(text='error E1042') -> RetrievalPayload(matches=[chunk_a]).",
      "input_ports": [
        {
          "key": "request",
          "label": "Request",
          "data_type": "query_request",
          "required": true,
          "accepts_many": false
        }
      ],
      "output_ports": [
        {
          "key": "results",
          "label": "Results",
          "data_type": "retrieval_results",
          "required": true,
          "accepts_many": false
        }
      ],
      "config_schema": {
        "$defs": {
          "IndexBackend": {
            "description": "Vector-store backends a pipeline can index into and query from.",
            "enum": ["pinecone", "pgvector"],
            "title": "IndexBackend",
            "type": "string"
          }
        },
        "description": "Configuration for BM25 (sparse/lexical) retriever nodes.\n\n`top_k` mirrors the dense retriever's override: set (typically to an\nexpression) to over-retrieve; unset uses the request's depth.",
        "properties": {
          "backend": {
            "$ref": "#/$defs/IndexBackend",
            "static_only": true
          },
          "index_name": {
            "default": "",
            "static_only": true,
            "title": "Index Name",
            "type": "string"
          },
          "namespace": {
            "default": "col-{collection_id}",
            "static_only": true,
            "title": "Namespace",
            "type": "string"
          },
          "top_k": {
            "anyOf": [
              {
                "exclusiveMinimum": 0,
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "description": "Override how many chunks to fetch; unset uses the request's top_k.",
            "title": "Top K"
          }
        },
        "title": "Bm25RetrieverConfig",
        "type": "object"
      },
      "default_config": {
        "backend": "pgvector",
        "index_name": "",
        "namespace": "col-{collection_id}",
        "top_k": null
      },
      "hidden": false
    },
    {
      "type": "fusion.rrf",
      "label": "RRF Fusion",
      "category": "retrieval",
      "description": "Combine results from multiple retrievers by reciprocal rank \u2014 robust fusion without comparable scores (e.g. semantic + BM25).",
      "example": "[semantic: (a, b), bm25: (b, c)] -> RetrievalPayload(b, a, c).",
      "input_ports": [
        {
          "key": "results",
          "label": "Results",
          "data_type": "retrieval_results",
          "required": true,
          "accepts_many": true
        }
      ],
      "output_ports": [
        {
          "key": "results",
          "label": "Results",
          "data_type": "retrieval_results",
          "required": true,
          "accepts_many": false
        }
      ],
      "config_schema": {
        "description": "Configuration for reciprocal rank fusion.\n\n`k` is the standard RRF dampening constant (Cormack et al.: 60): higher\nvalues flatten the difference between ranks. `top_k` caps the fused list;\nunset, it falls back to the run's requested top_k.",
        "properties": {
          "k": {
            "default": 60,
            "minimum": 1,
            "title": "K",
            "type": "integer"
          },
          "top_k": {
            "anyOf": [
              {
                "exclusiveMinimum": 0,
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "title": "Top K"
          }
        },
        "title": "RRFusionConfig",
        "type": "object"
      },
      "default_config": {
        "k": 60,
        "top_k": null
      },
      "hidden": false
    },
    {
      "type": "retrieval.output",
      "label": "Retrieval Output",
      "category": "retrieval",
      "description": "Emit retrieval results for the API.",
      "example": "RetrievalPayload(matches=2) -> Result(RetrievalPayload(matches=2)).",
      "input_ports": [
        {
          "key": "results",
          "label": "Results",
          "data_type": "retrieval_results",
          "required": true,
          "accepts_many": false
        }
      ],
      "output_ports": [
        {
          "key": "result",
          "label": "Result",
          "data_type": "retrieval_results",
          "required": true,
          "accepts_many": false
        }
      ],
      "config_schema": {
        "$defs": {
          "PipelineOutputField": {
            "description": "A named expression evaluated at run end and returned beside results.",
            "properties": {
              "name": {
                "maxLength": 64,
                "title": "Name",
                "type": "string"
              },
              "expression": {
                "default": "",
                "title": "Expression",
                "type": "string"
              }
            },
            "required": ["name"],
            "title": "PipelineOutputField",
            "type": "object"
          }
        },
        "description": "Configuration for retrieval output nodes.\n\n`outputs` declares extra named expressions evaluated against the run's\nvariable environment and returned beside the results (e.g. the effective\nover-retrieval depth). Purely additive: an empty list is today's behavior.",
        "properties": {
          "outputs": {
            "items": {
              "$ref": "#/$defs/PipelineOutputField"
            },
            "title": "Outputs",
            "type": "array"
          }
        },
        "title": "RetrievalOutputConfig",
        "type": "object"
      },
      "default_config": {
        "outputs": []
      },
      "hidden": false
    }
  ]
