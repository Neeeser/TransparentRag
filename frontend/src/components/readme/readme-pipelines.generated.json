  "node_specs": [
    {
      "type": "ingestion.input",
      "label": "Ingestion Input",
      "category": "ingestion",
      "description": "Build a document source from the uploaded file.",
      "example": "Context(document='file.pdf') -> SourcePayload(document_id='123', path='/tmp/file.pdf', content_type='application/pdf').",
      "input_ports": [],
      "output_ports": [
        {
          "key": "source",
          "label": "Source",
          "data_type": "document_source",
          "required": true,
          "accepts_many": false
        }
      ],
      "config_schema": {
        "description": "Configuration for ingestion input nodes.",
        "properties": {},
        "title": "IngestionInputConfig",
        "type": "object"
      },
      "default_config": {},
      "hidden": false
    },
    {
      "type": "parser.document",
      "label": "Document Parser",
      "category": "ingestion",
      "description": "Extract text from a document source.",
      "example": "SourcePayload(content_type='application/pdf') -> ParsedDocumentPayload(text='Invoice #42 ...').",
      "input_ports": [
        {
          "key": "source",
          "label": "Source",
          "data_type": "document_source",
          "required": true,
          "accepts_many": false
        }
      ],
      "output_ports": [
        {
          "key": "document",
          "label": "Document",
          "data_type": "document",
          "required": true,
          "accepts_many": false
        }
      ],
      "config_schema": {
        "description": "Configuration for document parsing.",
        "properties": {
          "mode": {
            "default": "auto",
            "enum": ["auto", "pdf", "text"],
            "title": "Mode",
            "type": "string"
          },
          "encoding": {
            "default": "utf-8",
            "title": "Encoding",
            "type": "string"
          }
        },
        "title": "ParserConfig",
        "type": "object"
      },
      "default_config": {
        "mode": "auto",
        "encoding": "utf-8"
      },
      "hidden": false
    },
    {
      "type": "chunker.token",
      "label": "Token Chunker",
      "category": "ingestion",
      "description": "Chunk documents based on token counts.",
      "example": "ParsedDocumentPayload(text='Hello world') -> ChunkPayload(chunks=['Hello', 'world']).",
      "input_ports": [
        {
          "key": "document",
          "label": "Document",
          "data_type": "document",
          "required": true,
          "accepts_many": false
        }
      ],
      "output_ports": [
        {
          "key": "chunks",
          "label": "Chunks",
          "data_type": "chunk_batch",
          "required": true,
          "accepts_many": false
        }
      ],
      "config_schema": {
        "description": "Configuration for fixed-strategy chunking nodes.",
        "properties": {
          "chunk_size": {
            "default": 512,
            "exclusiveMinimum": 0,
            "title": "Chunk Size",
            "type": "integer"
          },
          "chunk_overlap": {
            "default": 200,
            "minimum": 0,
            "title": "Chunk Overlap",
            "type": "integer"
          },
          "tokenizer": {
            "default": "wordpiece",
            "enum": ["wordpiece", "cl100k", "whitespace", "huggingface"],
            "title": "Tokenizer",
            "type": "string"
          },
          "hf_model_id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "title": "Hf Model Id"
          }
        },
        "title": "FixedChunkerConfig",
        "type": "object"
      },
      "default_config": {
        "chunk_size": 512,
        "chunk_overlap": 200,
        "tokenizer": "wordpiece",
        "hf_model_id": null
      },
      "hidden": false
    },
    {
      "type": "embedder.text",
      "label": "Embedder",
      "category": "ingestion",
      "description": "Embed text using a configured provider connection.",
      "example": "ChunkPayload(chunks=['hello']) -> EmbeddingPayload(embeddings=[[0.12, 0.03, ...]]).",
      "input_ports": [
        {
          "key": "chunks",
          "label": "Chunks",
          "data_type": "chunk_batch",
          "required": false,
          "accepts_many": false
        },
        {
          "key": "request",
          "label": "Request",
          "data_type": "query_request",
          "required": false,
          "accepts_many": false
        }
      ],
      "output_ports": [
        {
          "key": "embedded",
          "label": "Embedded",
          "data_type": "embedded_batch",
          "required": false,
          "accepts_many": false
        },
        {
          "key": "query_embedding",
          "label": "Query Embedding",
          "data_type": "query_embedding",
          "required": false,
          "accepts_many": false
        }
      ],
      "config_schema": {
        "description": "Configuration for embedding nodes.\n\n`connection_id` names the provider connection that serves the model; both\nit and `model_name` are required for a runnable node, but stay optional on\nthe model so an incomplete draft validates in the editor and surfaces\nthrough node validation instead of a parse crash.",
        "properties": {
          "connection_id": {
            "anyOf": [
              {
                "format": "uuid",
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "description": "Provider connection that serves the embedding model.",
            "static_only": true,
            "title": "Connection Id"
          },
          "model_name": {
            "default": "",
            "static_only": true,
            "title": "Model Name",
            "type": "string"
          },
          "dimension": {
            "anyOf": [
              {
                "exclusiveMinimum": 0,
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "description": "Optional override for the embedding vector dimension.",
            "static_only": true,
            "title": "Dimension"
          }
        },
        "title": "EmbedderConfig",
        "type": "object"
      },
      "default_config": {
        "connection_id": null,
        "model_name": "",
        "dimension": null
      },
      "hidden": false
    },
    {
      "type": "indexer.vector",
      "label": "Indexer",
      "category": "ingestion",
      "description": "Write embeddings into a vector index (pgvector or Pinecone).",
      "example": "EmbeddingPayload(chunks=2) -> IndexingPayload(chunks=2, index='docs').",
      "input_ports": [
        {
          "key": "embedded",
          "label": "Embedded",
          "data_type": "embedded_batch",
          "required": true,
          "accepts_many": false
        }
      ],
      "output_ports": [
        {
          "key": "indexed",
          "label": "Indexed",
          "data_type": "indexed_batch",
          "required": true,
          "accepts_many": false
        }
      ],
      "config_schema": {
        "$defs": {
          "IndexBackend": {
            "description": "Vector-store backends a pipeline can index into and query from.",
            "enum": ["pinecone", "pgvector"],
            "title": "IndexBackend",
            "type": "string"
          }
        },
        "description": "Unified indexer config: the target backend is data, not a node subtype.\n\n`index_name` deliberately defaults to empty -- an index must be chosen\nexplicitly, and validation flags a blank one (`missing_index_issue`).\nLegacy definitions that relied on the old per-backend defaults get theirs\nfilled by the startup migration (`app.pipelines.upgrades`).",
        "properties": {
          "index_name": {
            "default": "",
            "static_only": true,
            "title": "Index Name",
            "type": "string"
          },
          "namespace": {
            "default": "col-{collection_id}",
            "static_only": true,
            "title": "Namespace",
            "type": "string"
          },
          "dimension": {
            "anyOf": [
              {
                "exclusiveMinimum": 0,
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "static_only": true,
            "title": "Dimension"
          },
          "metric": {
            "default": "cosine",
            "static_only": true,
            "title": "Metric",
            "type": "string"
          },
          "ensure_index": {
            "default": true,
            "title": "Ensure Index",
            "type": "boolean"
          },
          "backend": {
            "$ref": "#/$defs/IndexBackend",
            "static_only": true
          }
        },
        "title": "VectorIndexerConfig",
        "type": "object"
      },
      "default_config": {
        "index_name": "",
        "namespace": "col-{collection_id}",
        "dimension": null,
        "metric": "cosine",
        "ensure_index": true,
        "backend": "pgvector"
      },
      "hidden": false
    },
    {
      "type": "indexer.bm25",
      "label": "BM25 Indexer",
      "category": "ingestion",
      "description": "Write chunk text into a sparse BM25 index for exact-term (lexical) search \u2014 no embeddings involved.",
      "example": "ChunkPayload(chunks=2) -> IndexingPayload(chunks=2, index='docs-bm25').",
      "input_ports": [
        {
          "key": "chunks",
          "label": "Chunks",
          "data_type": "chunk_batch",
          "required": true,
          "accepts_many": false
        }
      ],
      "output_ports": [
        {
          "key": "indexed",
          "label": "Indexed",
          "data_type": "indexed_batch",
          "required": true,
          "accepts_many": false
        }
      ],
      "config_schema": {
        "$defs": {
          "IndexBackend": {
            "description": "Vector-store backends a pipeline can index into and query from.",
            "enum": ["pinecone", "pgvector"],
            "title": "IndexBackend",
            "type": "string"
          }
        },
        "description": "Configuration for BM25 (sparse/lexical) indexing nodes.\n\nNo dimension or metric: sparse indexes are text-scored (pg_search BM25 /\nPinecone's integrated sparse model). `index_name` defaults to empty like\nthe unified dense indexer \u2014 an index must be chosen explicitly.",
        "properties": {
          "backend": {
            "$ref": "#/$defs/IndexBackend",
            "static_only": true
          },
          "index_name": {
            "default": "",
            "static_only": true,
            "title": "Index Name",
            "type": "string"
          },
          "namespace": {
            "default": "col-{collection_id}",
            "static_only": true,
            "title": "Namespace",
            "type": "string"
          },
          "ensure_index": {
            "default": true,
            "title": "Ensure Index",
            "type": "boolean"
          }
        },
        "title": "Bm25IndexerConfig",
        "type": "object"
      },
      "default_config": {
        "backend": "pgvector",
        "index_name": "",
        "namespace": "col-{collection_id}",
        "ensure_index": true
      },
      "hidden": false
    },
    {
      "type": "ingestion.output",
      "label": "Ingestion Output",
      "category": "ingestion",
      "description": "Emit the indexed chunks for persistence.",
      "example": "IndexingPayload(chunks=2) -> Result(IndexingPayload(chunks=2)).",
      "input_ports": [
        {
          "key": "indexed",
          "label": "Indexed",
          "data_type": "indexed_batch",
          "required": true,
          "accepts_many": true
        }
      ],
      "output_ports": [
        {
          "key": "result",
          "label": "Result",
          "data_type": "indexed_batch",
          "required": true,
          "accepts_many": false
        }
      ],
      "config_schema": {
        "description": "Configuration for ingestion output nodes.",
        "properties": {},
        "title": "IngestionOutputConfig",
        "type": "object"
      },
      "default_config": {},
      "hidden": false
    },
    {
      "type": "retrieval.input",
      "label": "Retrieval Input",
      "category": "retrieval",
      "description": "Provide the query payload for retrieval.",
      "example": "Query='coffee', top_k=3 -> QueryRequest(text='coffee', top_k=3).",
      "input_ports": [],
      "output_ports": [
        {
          "key": "request",
          "label": "Request",
          "data_type": "query_request",
          "required": true,
          "accepts_many": false
        }
      ],
      "config_schema": {
        "$defs": {
          "PipelineInputArgument": {
            "description": "A caller-supplied retrieval argument declared on `retrieval.input`.\n\n`required` arguments must be supplied by the caller; optional arguments\nmust declare a `default` (enforced by validation) so expressions always\nhave a value. `expose_to_llm` publishes the argument in the chat tool\nschema; the `model` type is panel-only and never valid here.",
            "properties": {
              "name": {
                "maxLength": 64,
                "title": "Name",
                "type": "string"
              },
              "type": {
                "$ref": "#/$defs/VariableType",
                "default": "string"
              },
              "description": {
                "default": "",
                "title": "Description",
                "type": "string"
              },
              "required": {
                "default": false,
                "title": "Required",
                "type": "boolean"
              },
              "default": {
                "anyOf": [
                  {
                    "type": "integer"
                  },
                  {
                    "type": "number"
                  },
                  {
                    "type": "string"
                  },
                  {
                    "type": "boolean"
                  },
                  {
                    "type": "null"
                  }
                ],
                "default": null,
                "title": "Default"
              },
              "minimum": {
                "anyOf": [
                  {
                    "type": "number"
                  },
                  {
                    "type": "null"
                  }
                ],
                "default": null,
                "title": "Minimum"
              },
              "maximum": {
                "anyOf": [
                  {
                    "type": "number"
                  },
                  {
                    "type": "null"
                  }
                ],
                "default": null,
                "title": "Maximum"
              },
              "choices": {
                "items": {
                  "type": "string"
                },
                "title": "Choices",
                "type": "array"
              },
              "expose_to_llm": {
                "default": false,
                "title": "Expose To Llm",
                "type": "boolean"
              }
            },
            "required": ["name"],
            "title": "PipelineInputArgument",
            "type": "object"
          },
          "VariableType": {
            "description": "Declared types for pipeline variables and input arguments.",
            "enum": ["integer", "number", "string", "boolean", "enum", "model"],
            "title": "VariableType",
            "type": "string"
          }
        },
        "description": "Configuration for retrieval input nodes.\n\n`arguments` declares the caller-supplied inputs this pipeline accepts \u2014\nthe search page renders a control per entry and the chat tool schema\npublishes the `expose_to_llm` ones. The built-in `query` argument is\nimplicit and always present.",
        "properties": {
          "arguments": {
            "items": {
              "$ref": "#/$defs/PipelineInputArgument"
            },
            "title": "Arguments",
            "type": "array"
          }
        },
        "title": "RetrievalInputConfig",
        "type": "object"
      },
      "default_config": {
        "arguments": []
      },
      "hidden": false
    },
    {
      "type": "retriever.vector",
      "label": "Retriever",
      "category": "retrieval",
      "description": "Query a vector index (pgvector or Pinecone) for matching chunks.",
      "example": "QueryEmbedding(request='coffee', embedding=[0.1, 0.2]) -> RetrievalPayload(matches=[chunk_a, chunk_b]).",
      "input_ports": [
        {
          "key": "query_embedding",
          "label": "Query Embedding",
          "data_type": "query_embedding",
          "required": true,
          "accepts_many": false
        }
      ],
      "output_ports": [
        {
          "key": "results",
          "label": "Results",
          "data_type": "retrieval_results",
          "required": true,
          "accepts_many": false
        }
      ],
      "config_schema": {
        "$defs": {
          "IndexBackend": {
            "description": "Vector-store backends a pipeline can index into and query from.",
            "enum": ["pinecone", "pgvector"],
            "title": "IndexBackend",
            "type": "string"
          }
        },
        "description": "Unified retriever config: the target backend is data, not a node subtype.\n\n`index_name` deliberately defaults to empty -- an index must be chosen\nexplicitly, and validation flags a blank one (`missing_index_issue`).\nLegacy definitions that relied on the old per-backend defaults get theirs\nfilled by the startup migration (`app.pipelines.upgrades`).",
        "properties": {
          "index_name": {
            "default": "",
            "static_only": true,
            "title": "Index Name",
            "type": "string"
          },
          "namespace": {
            "default": "col-{collection_id}",
            "static_only": true,
            "title": "Namespace",
            "type": "string"
          },
          "top_k": {
            "anyOf": [
              {
                "exclusiveMinimum": 0,
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "description": "Override how many chunks to fetch; unset uses the request's top_k.",
            "title": "Top K"
          },
          "backend": {
            "$ref": "#/$defs/IndexBackend",
            "static_only": true
          }
        },
        "title": "VectorRetrieverConfig",
        "type": "object"
      },
      "default_config": {
