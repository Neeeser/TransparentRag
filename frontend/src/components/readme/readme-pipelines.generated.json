  "node_specs": [
    {
      "type": "ingestion.input",
      "label": "Ingestion Input",
      "category": "ingestion",
      "description": "Build a document source from the uploaded file.",
      "example": "Context(document='file.pdf') -> SourcePayload(document_id='123', path='/tmp/file.pdf', content_type='application/pdf').",
      "input_ports": [],
      "output_ports": [
        {
          "key": "source",
          "label": "Source",
          "data_type": "document_source",
          "required": true,
          "accepts_many": false
        }
      ],
      "config_schema": {
        "description": "Configuration for ingestion input nodes.",
        "properties": {},
        "title": "IngestionInputConfig",
        "type": "object"
      },
      "default_config": {},
      "hidden": false
    },
    {
      "type": "parser.document",
      "label": "Document Parser",
      "category": "ingestion",
      "description": "Extract text from a document source.",
      "example": "SourcePayload(content_type='application/pdf') -> ParsedDocumentPayload(text='Invoice #42 ...').",
      "input_ports": [
        {
          "key": "source",
          "label": "Source",
          "data_type": "document_source",
          "required": true,
          "accepts_many": false
        }
      ],
      "output_ports": [
        {
          "key": "document",
          "label": "Document",
          "data_type": "document",
          "required": true,
          "accepts_many": false
        }
      ],
      "config_schema": {
        "description": "Configuration for document parsing.",
        "properties": {
          "mode": {
            "default": "auto",
            "enum": ["auto", "pdf", "text"],
            "title": "Mode",
            "type": "string"
          },
          "encoding": {
            "default": "utf-8",
            "title": "Encoding",
            "type": "string"
          }
        },
        "title": "ParserConfig",
        "type": "object"
      },
      "default_config": {
        "mode": "auto",
        "encoding": "utf-8"
      },
      "hidden": false
    },
    {
      "type": "chunker.token",
      "label": "Token Chunker",
      "category": "ingestion",
      "description": "Chunk documents based on token counts.",
      "example": "ParsedDocumentPayload(text='Hello world') -> ChunkPayload(chunks=['Hello', 'world']).",
      "input_ports": [
        {
          "key": "document",
          "label": "Document",
          "data_type": "document",
          "required": true,
          "accepts_many": false
        }
      ],
      "output_ports": [
        {
          "key": "chunks",
          "label": "Chunks",
          "data_type": "chunk_batch",
          "required": true,
          "accepts_many": false
        }
      ],
      "config_schema": {
        "description": "Configuration for fixed-strategy chunking nodes.",
        "properties": {
          "chunk_size": {
            "default": 512,
            "exclusiveMinimum": 0,
            "title": "Chunk Size",
            "type": "integer"
          },
          "chunk_overlap": {
            "default": 200,
            "minimum": 0,
            "title": "Chunk Overlap",
            "type": "integer"
          }
        },
        "title": "FixedChunkerConfig",
        "type": "object"
      },
      "default_config": {
        "chunk_size": 512,
        "chunk_overlap": 200
      },
      "hidden": false
    },
    {
      "type": "embedder.openrouter",
      "label": "Embedder",
      "category": "ingestion",
      "description": "Embed chunks using OpenRouter.",
      "example": "ChunkPayload(chunks=['hello']) -> EmbeddingPayload(embeddings=[[0.12, 0.03, ...]]).",
      "input_ports": [
        {
          "key": "chunks",
          "label": "Chunks",
          "data_type": "chunk_batch",
          "required": false,
          "accepts_many": false
        },
        {
          "key": "request",
          "label": "Request",
          "data_type": "query_request",
          "required": false,
          "accepts_many": false
        }
      ],
      "output_ports": [
        {
          "key": "embedded",
          "label": "Embedded",
          "data_type": "embedded_batch",
          "required": false,
          "accepts_many": false
        },
        {
          "key": "query_embedding",
          "label": "Query Embedding",
          "data_type": "query_embedding",
          "required": false,
          "accepts_many": false
        }
      ],
      "config_schema": {
        "description": "Configuration for embedding nodes.",
        "properties": {
          "model_name": {
            "title": "Model Name",
            "type": "string"
          },
          "dimension": {
            "anyOf": [
              {
                "exclusiveMinimum": 0,
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "description": "Optional override for the embedding vector dimension.",
            "title": "Dimension"
          }
        },
        "title": "EmbedderConfig",
        "type": "object"
      },
      "default_config": {
        "model_name": "",
        "dimension": null
      },
      "hidden": false
    },
    {
      "type": "indexer.vector",
      "label": "Indexer",
      "category": "ingestion",
      "description": "Write embeddings into a vector index (pgvector or Pinecone).",
      "example": "EmbeddingPayload(chunks=2) -> IndexingPayload(chunks=2, index='docs').",
      "input_ports": [
        {
          "key": "embedded",
          "label": "Embedded",
          "data_type": "embedded_batch",
          "required": true,
          "accepts_many": false
        }
      ],
      "output_ports": [
        {
          "key": "indexed",
          "label": "Indexed",
          "data_type": "indexed_batch",
          "required": true,
          "accepts_many": false
        }
      ],
      "config_schema": {
        "$defs": {
          "IndexBackend": {
            "description": "Vector-store backends a pipeline can index into and query from.",
            "enum": ["pinecone", "pgvector"],
            "title": "IndexBackend",
            "type": "string"
          }
        },
        "description": "Unified indexer config: the target backend is data, not a node subtype.\n\n`index_name` deliberately defaults to empty -- an index must be chosen\nexplicitly, and validation flags a blank one (`missing_index_issue`).\nLegacy definitions that relied on the old per-backend defaults get theirs\nfilled by the startup migration (`app.pipelines.upgrades`).",
        "properties": {
          "index_name": {
            "default": "",
            "title": "Index Name",
            "type": "string"
          },
          "namespace": {
            "default": "col-{collection_id}",
            "title": "Namespace",
            "type": "string"
          },
          "dimension": {
            "anyOf": [
              {
                "exclusiveMinimum": 0,
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "title": "Dimension"
          },
          "metric": {
            "default": "cosine",
            "title": "Metric",
            "type": "string"
          },
          "ensure_index": {
            "default": true,
            "title": "Ensure Index",
            "type": "boolean"
          },
          "backend": {
            "$ref": "#/$defs/IndexBackend"
          }
        },
        "title": "VectorIndexerConfig",
        "type": "object"
      },
      "default_config": {
        "index_name": "",
        "namespace": "col-{collection_id}",
        "dimension": null,
        "metric": "cosine",
        "ensure_index": true,
        "backend": "pgvector"
      },
      "hidden": false
    },
    {
      "type": "indexer.bm25",
      "label": "BM25 Indexer",
      "category": "ingestion",
      "description": "Write chunk text into a sparse BM25 index for exact-term (lexical) search \u2014 no embeddings involved.",
      "example": "ChunkPayload(chunks=2) -> IndexingPayload(chunks=2, index='docs-bm25').",
      "input_ports": [
        {
          "key": "chunks",
          "label": "Chunks",
          "data_type": "chunk_batch",
          "required": true,
          "accepts_many": false
        }
      ],
      "output_ports": [
        {
          "key": "indexed",
          "label": "Indexed",
          "data_type": "indexed_batch",
          "required": true,
          "accepts_many": false
        }
      ],
      "config_schema": {
        "$defs": {
          "IndexBackend": {
            "description": "Vector-store backends a pipeline can index into and query from.",
            "enum": ["pinecone", "pgvector"],
            "title": "IndexBackend",
            "type": "string"
          }
        },
        "description": "Configuration for BM25 (sparse/lexical) indexing nodes.\n\nNo dimension or metric: sparse indexes are text-scored (pg_search BM25 /\nPinecone's integrated sparse model). `index_name` defaults to empty like\nthe unified dense indexer \u2014 an index must be chosen explicitly.",
        "properties": {
          "backend": {
            "$ref": "#/$defs/IndexBackend"
          },
          "index_name": {
            "default": "",
            "title": "Index Name",
            "type": "string"
          },
          "namespace": {
            "default": "col-{collection_id}",
            "title": "Namespace",
            "type": "string"
          },
          "ensure_index": {
            "default": true,
            "title": "Ensure Index",
            "type": "boolean"
          }
        },
        "title": "Bm25IndexerConfig",
        "type": "object"
      },
      "default_config": {
        "backend": "pgvector",
        "index_name": "",
        "namespace": "col-{collection_id}",
        "ensure_index": true
      },
      "hidden": false
    },
    {
      "type": "ingestion.output",
      "label": "Ingestion Output",
      "category": "ingestion",
      "description": "Emit the indexed chunks for persistence.",
      "example": "IndexingPayload(chunks=2) -> Result(IndexingPayload(chunks=2)).",
      "input_ports": [
