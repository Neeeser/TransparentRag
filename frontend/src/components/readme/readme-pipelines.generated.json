      "input_ports": [
        {
          "key": "query_embedding",
          "label": "Query Embedding",
          "data_type": "query_embedding",
          "required": true,
          "accepts_many": false
        }
      ],
      "output_ports": [
        {
          "key": "results",
          "label": "Results",
          "data_type": "retrieval_results",
          "required": true,
          "accepts_many": false
        }
      ],
      "config_schema": {
        "$defs": {
          "IndexBackend": {
            "description": "Vector-store backends a pipeline can index into and query from.",
            "enum": ["pinecone", "pgvector"],
            "title": "IndexBackend",
            "type": "string"
          }
        },
        "description": "Unified retriever config: the target backend is data, not a node subtype.\n\n`index_name` deliberately defaults to empty -- an index must be chosen\nexplicitly, and validation flags a blank one (`missing_index_issue`).\nLegacy definitions that relied on the old per-backend defaults get theirs\nfilled by the startup migration (`app.pipelines.upgrades`).",
        "properties": {
