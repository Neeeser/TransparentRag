  "node_specs": [
    {
      "type": "ingestion.input",
      "label": "Ingestion Input",
      "category": "ingestion",
      "description": "Build a document source from the uploaded file.",
      "example": "Context(document='file.pdf') -> SourcePayload(document_id='123', path='/tmp/file.pdf', content_type='application/pdf').",
      "input_ports": [],
      "output_ports": [
        {
          "key": "source",
          "label": "Source",
          "data_type": "document_source",
          "required": true,
          "accepts_many": false
        }
      ],
      "config_schema": {
        "description": "Configuration for ingestion input nodes.",
        "properties": {},
        "title": "IngestionInputConfig",
        "type": "object"
      },
      "default_config": {},
      "hidden": false,
      "supported_backends": null
    },
    {
      "type": "parser.document",
      "label": "Document Parser",
      "category": "ingestion",
      "description": "Extract text from a document source.",
      "example": "SourcePayload(content_type='application/pdf') -> ParsedDocumentPayload(text='Invoice #42 ...').",
      "input_ports": [
        {
          "key": "source",
          "label": "Source",
          "data_type": "document_source",
          "required": true,
          "accepts_many": false
        }
      ],
      "output_ports": [
        {
          "key": "document",
          "label": "Document",
          "data_type": "document",
          "required": true,
          "accepts_many": false
        }
      ],
      "config_schema": {
        "description": "Configuration for document parsing.",
        "properties": {
          "mode": {
            "default": "auto",
            "enum": [
              "auto",
              "pdf",
              "text"
            ],
            "title": "Mode",
            "type": "string"
          },
          "encoding": {
            "default": "utf-8",
            "title": "Encoding",
            "type": "string"
          }
        },
        "title": "ParserConfig",
        "type": "object"
      },
      "default_config": {
        "mode": "auto",
        "encoding": "utf-8"
      },
      "hidden": false,
      "supported_backends": null
    },
    {
      "type": "chunker.token",
      "label": "Token Chunker",
      "category": "ingestion",
      "description": "Chunk documents based on token counts.",
      "example": "ParsedDocumentPayload(text='Hello world') -> ChunkPayload(chunks=['Hello', 'world']).",
      "input_ports": [
        {
          "key": "document",
          "label": "Document",
          "data_type": "document",
          "required": true,
          "accepts_many": false
        }
      ],
      "output_ports": [
        {
          "key": "chunks",
          "label": "Chunks",
          "data_type": "chunk_batch",
          "required": true,
          "accepts_many": false
        }
      ],
      "config_schema": {
        "description": "Configuration for fixed-strategy chunking nodes.",
        "properties": {
          "chunk_size": {
            "default": 512,
            "description": "Maximum tokens per chunk, counted by the selected tokenizer. Larger chunks keep more context around each match but dilute the embedding and eat into the model's input limit; smaller chunks match more precisely but fragment context.",
            "exclusiveMinimum": 0,
            "title": "Chunk Size",
            "type": "integer"
          },
          "chunk_overlap": {
            "default": 200,
            "description": "Tokens repeated from the end of one chunk at the start of the next, so text straddling a boundary stays retrievable from both sides. The cost is index size \u2014 overlapped tokens are stored and embedded twice.",
            "minimum": 0,
            "title": "Chunk Overlap",
            "type": "integer"
          },
          "tokenizer": {
            "default": "wordpiece",
            "description": "Counter used to measure chunk_size and overlap. Match the embedding model's own tokenizer \u2014 wordpiece for BERT-family embedders, cl100k for OpenAI-family. whitespace counts words, not tokens, and undercounts by roughly 25%.",
            "enum": [
              "wordpiece",
              "cl100k",
              "whitespace",
              "huggingface"
            ],
            "title": "Tokenizer",
            "type": "string"
          },
          "hf_model_id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "description": "HuggingFace model id whose tokenizer to download and count with. Only used (and required) when tokenizer is huggingface.",
            "title": "Hf Model Id"
          }
        },
        "title": "FixedChunkerConfig",
        "type": "object"
      },
      "default_config": {
        "chunk_size": 512,
        "chunk_overlap": 200,
        "tokenizer": "wordpiece",
        "hf_model_id": null
      },
      "hidden": false,
      "supported_backends": null
    },
    {
      "type": "embedder.text",
      "label": "Embedder",
      "category": "ingestion",
      "description": "Embed text using a configured provider connection.",
      "example": "ChunkPayload(chunks=['hello']) -> EmbeddingPayload(embeddings=[[0.12, 0.03, ...]]).",
      "input_ports": [
        {
          "key": "chunks",
          "label": "Chunks",
          "data_type": "chunk_batch",
          "required": false,
          "accepts_many": false
        },
        {
          "key": "request",
          "label": "Request",
          "data_type": "query_request",
          "required": false,
          "accepts_many": false
        }
      ],
      "output_ports": [
        {
          "key": "embedded",
          "label": "Embedded",
          "data_type": "embedded_batch",
          "required": false,
          "accepts_many": false
        },
        {
          "key": "query_embedding",
          "label": "Query Embedding",
          "data_type": "query_embedding",
          "required": false,
          "accepts_many": false
        }
      ],
      "config_schema": {
        "description": "Configuration for embedding nodes.\n\n`connection_id` names the provider connection that serves the model; both\nit and `model_name` are required for a runnable node, but stay optional on\nthe model so an incomplete draft validates in the editor and surfaces\nthrough node validation instead of a parse crash.",
        "properties": {
          "connection_id": {
            "anyOf": [
              {
                "format": "uuid",
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "description": "Provider connection that serves the embedding model.",
            "static_only": true,
            "title": "Connection Id"
          },
          "model_name": {
            "default": "",
            "static_only": true,
            "title": "Model Name",
            "type": "string"
          },
          "dimension": {
            "anyOf": [
              {
                "exclusiveMinimum": 0,
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "description": "Requested output dimension, for models that support reduced (Matryoshka-style) embeddings. Leave unset to store the model's native dimension \u2014 most embedding models only serve that size and error on an explicit request.",
            "static_only": true,
            "title": "Dimension"
          }
        },
        "title": "EmbedderConfig",
        "type": "object"
      },
      "default_config": {
        "connection_id": null,
        "model_name": "",
        "dimension": null
      },
      "hidden": false,
      "supported_backends": null
    },
    {
      "type": "indexer.vector",
      "label": "Indexer",
      "category": "ingestion",
      "description": "Write embeddings into a vector index (pgvector or Pinecone).",
      "example": "EmbeddingPayload(chunks=2) -> IndexingPayload(chunks=2, index='docs').",
      "input_ports": [
        {
          "key": "embedded",
          "label": "Embedded",
          "data_type": "embedded_batch",
          "required": true,
          "accepts_many": false
        }
      ],
      "output_ports": [
        {
          "key": "indexed",
          "label": "Indexed",
          "data_type": "indexed_batch",
          "required": true,
          "accepts_many": false
        }
      ],
      "config_schema": {
        "$defs": {
          "IndexBackend": {
            "description": "Vector-store backends a pipeline can index into and query from.",
            "enum": [
              "pinecone",
              "pgvector"
            ],
            "title": "IndexBackend",
            "type": "string"
          }
        },
        "description": "Unified indexer config: the target backend is data, not a node subtype.\n\n`index_name` deliberately defaults to empty -- an index must be chosen\nexplicitly, and validation flags a blank one (`missing_index_issue`).\nLegacy definitions that relied on the old per-backend defaults get theirs\nfilled by the startup migration (`app.pipelines.upgrades`).",
        "properties": {
          "index_name": {
            "default": "",
            "static_only": true,
            "title": "Index Name",
            "type": "string"
          },
          "namespace": {
            "default": "col-{collection_id}",
            "static_only": true,
            "title": "Namespace",
            "type": "string"
          },
          "dimension": {
            "anyOf": [
              {
                "exclusiveMinimum": 0,
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "description": "Vector length the index is created with. Must equal the connected embedding model's output dimension \u2014 validation compares them, and a mismatched index rejects every upsert.",
            "static_only": true,
            "title": "Dimension"
          },
          "metric": {
            "default": "cosine",
            "description": "Distance function the index scores matches with. Match how the embedding model was trained \u2014 cosine for nearly all sentence embedders; changing it changes what 'similar' means.",
            "static_only": true,
            "title": "Metric",
            "type": "string"
          },
          "ensure_index": {
            "default": true,
            "description": "Create the index on first ingest if it does not exist. Disable to require pre-provisioned indexes \u2014 runs fail instead of creating one.",
            "title": "Ensure Index",
            "type": "boolean"
          },
          "backend": {
            "$ref": "#/$defs/IndexBackend",
            "static_only": true
          }
        },
        "title": "VectorIndexerConfig",
        "type": "object"
      },
      "default_config": {
        "index_name": "",
        "namespace": "col-{collection_id}",
        "dimension": null,
        "metric": "cosine",
        "ensure_index": true,
        "backend": "pgvector"
      },
      "hidden": false,
      "supported_backends": [
        "pgvector",
        "pinecone"
      ]
    },
    {
      "type": "indexer.bm25",
      "label": "BM25 Indexer",
      "category": "ingestion",
      "description": "Write chunk text into a sparse BM25 index for exact-term (lexical) search \u2014 no embeddings involved.",
      "example": "ChunkPayload(chunks=2) -> IndexingPayload(chunks=2, index='docs-bm25').",
      "input_ports": [
        {
          "key": "chunks",
          "label": "Chunks",
          "data_type": "chunk_batch",
          "required": true,
          "accepts_many": false
        }
      ],
      "output_ports": [
        {
          "key": "indexed",
          "label": "Indexed",
          "data_type": "indexed_batch",
          "required": true,
          "accepts_many": false
        }
      ],
      "config_schema": {
        "$defs": {
          "IndexBackend": {
            "description": "Vector-store backends a pipeline can index into and query from.",
            "enum": [
              "pinecone",
              "pgvector"
            ],
            "title": "IndexBackend",
            "type": "string"
          }
        },
        "description": "Configuration for BM25 (sparse/lexical) indexing nodes.\n\nNo dimension or metric: sparse indexes are text-scored (pg_search BM25 /\nPinecone's integrated sparse model). `index_name` defaults to empty like\nthe unified dense indexer \u2014 an index must be chosen explicitly.",
        "properties": {
          "backend": {
            "$ref": "#/$defs/IndexBackend",
            "static_only": true
          },
          "index_name": {
            "default": "",
            "static_only": true,
            "title": "Index Name",
            "type": "string"
          },
          "namespace": {
            "default": "col-{collection_id}",
            "static_only": true,
            "title": "Namespace",
            "type": "string"
          },
          "ensure_index": {
            "default": true,
            "title": "Ensure Index",
            "type": "boolean"
          }
        },
        "title": "Bm25IndexerConfig",
        "type": "object"
      },
      "default_config": {
        "backend": "pgvector",
        "index_name": "",
        "namespace": "col-{collection_id}",
        "ensure_index": true
      },
      "hidden": false,
      "supported_backends": [
        "pgvector",
        "pinecone"
      ]
    },
    {
      "type": "ingestion.output",
      "label": "Ingestion Output",
      "category": "ingestion",
      "description": "Emit the indexed chunks for persistence.",
      "example": "IndexingPayload(chunks=2) -> Result(IndexingPayload(chunks=2)).",
      "input_ports": [
        {
          "key": "indexed",
          "label": "Indexed",
          "data_type": "indexed_batch",
          "required": true,
          "accepts_many": true
        }
      ],
      "output_ports": [
        {
          "key": "result",
          "label": "Result",
          "data_type": "indexed_batch",
          "required": true,
          "accepts_many": false
        }
      ],
      "config_schema": {
        "description": "Configuration for ingestion output nodes.",
        "properties": {},
        "title": "IngestionOutputConfig",
        "type": "object"
      },
      "default_config": {},
      "hidden": false,
      "supported_backends": null
    },
    {
      "type": "retrieval.input",
      "label": "Retrieval Input",
      "category": "retrieval",
      "description": "Provide the query payload for retrieval.",
      "example": "Query='coffee', top_k=3 -> QueryRequest(text='coffee', top_k=3).",
      "input_ports": [],
      "output_ports": [
        {
          "key": "request",
          "label": "Request",
          "data_type": "query_request",
          "required": true,
          "accepts_many": false
        }
      ],
      "config_schema": {
        "description": "Configuration for query input nodes.\n\n`arguments` lists the names of input-source variables (declared on\n`PipelineDefinition.variables`) this pipeline accepts from callers \u2014 the\nsearch page renders a control per accepted variable and the chat tool\nschema publishes the `expose_to_llm` ones. The built-in `query` argument\nis implicit and always present. Definition/bounds/default live on the\nvariable, never here.\n\n`tool_name`/`tool_description` are the pipeline's tool identity \u2014 the\nbase name and description chat and MCP expose (namespaced per collection\nat exposure time). Unset, the identity falls back to the generic search\nprojection, which keeps pre-tools pipelines exposing today's\n`search_<collection>` contract unchanged.",
        "properties": {
          "arguments": {
            "items": {
              "type": "string"
            },
            "title": "Arguments",
            "type": "array"
          },
          "tool_name": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "title": "Tool Name"
          },
          "tool_description": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "title": "Tool Description"
          }
        },
        "title": "RetrievalInputConfig",
        "type": "object"
      },
      "default_config": {
        "arguments": [],
        "tool_name": null,
        "tool_description": null
      },
      "hidden": false,
      "supported_backends": null
    },
    {
      "type": "retriever.vector",
      "label": "Retriever",
      "category": "retrieval",
      "description": "Query a vector index (pgvector or Pinecone) for matching chunks.",
      "example": "QueryEmbedding(request='coffee', embedding=[0.1, 0.2]) -> RetrievalPayload(matches=[chunk_a, chunk_b]).",
      "input_ports": [
        {
          "key": "query_embedding",
          "label": "Query Embedding",
          "data_type": "query_embedding",
          "required": true,
          "accepts_many": false
        }
      ],
      "output_ports": [
        {
          "key": "results",
          "label": "Results",
          "data_type": "retrieval_results",
          "required": true,
          "accepts_many": false
        }
      ],
      "config_schema": {
        "$defs": {
          "IndexBackend": {
            "description": "Vector-store backends a pipeline can index into and query from.",
            "enum": [
              "pinecone",
              "pgvector"
            ],
            "title": "IndexBackend",
            "type": "string"
          }
        },
        "description": "Unified retriever config: the target backend is data, not a node subtype.\n\n`index_name` deliberately defaults to empty -- an index must be chosen\nexplicitly, and validation flags a blank one (`missing_index_issue`).\nLegacy definitions that relied on the old per-backend defaults get theirs\nfilled by the startup migration (`app.pipelines.upgrades`).",
        "properties": {
          "index_name": {
            "default": "",
            "static_only": true,
            "title": "Index Name",
            "type": "string"
          },
          "namespace": {
            "default": "col-{collection_id}",
            "static_only": true,
            "title": "Namespace",
            "type": "string"
          },
          "top_k": {
            "anyOf": [
              {
                "exclusiveMinimum": 0,
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "description": "How many chunks to fetch \u2014 typically the top_k variable, or an expression like top_k * 2 to over-retrieve for fusion/reranking.",
            "title": "Top K"
          },
          "backend": {
            "$ref": "#/$defs/IndexBackend",
            "static_only": true
          }
        },
        "title": "VectorRetrieverConfig",
        "type": "object"
      },
      "default_config": {
        "index_name": "",
        "namespace": "col-{collection_id}",
