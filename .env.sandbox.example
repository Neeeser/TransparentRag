# Provider keys for the sandbox scenario harness (`uv run python -m sandbox`).
# Copy to `.env.sandbox` (gitignored) and fill in the keys you have. Scenarios
# declare which keys they need; keyless scenarios run without this file.
# Loaded only by the harness — the app itself never reads it.

OPENROUTER_API_KEY=

# Optional overrides (defaults shown):
# SANDBOX_EMBEDDING_MODEL=openai/text-embedding-3-small
# SANDBOX_CHAT_MODEL=openai/gpt-4o-mini
# SANDBOX_DATABASE_URL=postgresql+psycopg://ragworks:ragworks@localhost:54329/ragworks_sandbox
