# Provider credentials for the sandbox scenario harness (`uv run python -m sandbox`).
# Copy to `.env.sandbox` (gitignored) and fill in the providers you have. Scenarios
# declare which providers they need; keyless scenarios run without this file.
# Loaded only by the harness — the app itself never reads it.
#
# Each provider's config shape is declared in `sandbox/keys.py` (PROVIDER_SPECS);
# add a provider's vars here in the same change you add it there, so this file
# stays the accurate list of what a scenario can require.

OPENROUTER_API_KEY=

# Cohere (embeddings + reranking):
# COHERE_API_KEY=

# Pinecone (vector store):
# PINECONE_API_KEY=

# Ollama — base-URL provider (API key optional, only if your server requires one):
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_API_KEY=

# Text Embeddings Inference (TEI) — base-URL provider (API key optional):
# TEI_BASE_URL=http://localhost:8080
# TEI_API_KEY=

# Optional model overrides (defaults shown):
# SANDBOX_EMBEDDING_MODEL=openai/text-embedding-3-small
# SANDBOX_CHAT_MODEL=openai/gpt-4o-mini
# SANDBOX_DATABASE_URL=postgresql+psycopg://ragworks:ragworks@localhost:54329/ragworks_sandbox
