# --- Required ---------------------------------------------------------------
# Secret used to sign auth tokens. Generate one with:
#   openssl rand -hex 32
JWT_SECRET_KEY=

# Password for the bundled Postgres instance (used only inside the compose
# network). Compose interpolates this straight into DATABASE_URL, so a value
# containing @ : # or / corrupts the URL. Generate a URL-safe value with:
#   openssl rand -hex 32
POSTGRES_PASSWORD=

# --- Optional ---------------------------------------------------------------
# Image tag to run, e.g. 0.2.0 (no v prefix). Defaults to latest.
#RAGWORKS_VERSION=latest

# Host port for the web UI. Defaults to 3000.
#FRONTEND_PORT=3000
